            <![CDATA[
#include "doc_converter.h"

char get_doc_char_at(unsigned char* doc_data, int doc_size, int text_offset, int char_index) {
    if (doc_data == NULL) {
        return (char)0xff;
    }

    /* 
     * Directly calculate offset and read character.
     * Vulnerability: Does not validate whether text_offset + char_index exceeds doc_size,
     * nor checks if offset or index are negative, leading to out-of-bounds read.
     */
    return (char)doc_data[text_offset + char_index];
}
        ]]>
        </content>
    </code>
</result>
```


